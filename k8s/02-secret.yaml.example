# SZABLON. Skopiuj do 02-secret.yaml, uzupelnij wartosci i NIE commituj.
# Wartosci pobierzesz z `terraform output rds_address` itp. po terraform apply.
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: currency-monitor
type: Opaque
stringData:
  ConnectionStrings__Postgres: "Host=RDS_HOSTNAME_HERE;Port=5432;Database=currency;Username=postgres;Password=YOUR_PASSWORD_HERE"