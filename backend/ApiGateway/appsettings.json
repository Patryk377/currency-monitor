{
  "ReverseProxy": {
    "Routes": {
      "rates-route": {
        "ClusterId": "rates-cluster",
        "Match": {
          "Path": "/api/rates/{**catch-all}"
        }
      },
      "alerts-route": {
        "ClusterId": "alerts-cluster",
        "Match": {
          "Path": "/api/alerts/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "rates-cluster": {
        "Destinations": {
          "rates": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "alerts-cluster": {
        "Destinations": {
          "alerts": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}